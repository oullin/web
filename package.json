{
	"name": "oullin-web",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"watch": "make local-watch",
		"test": "vitest run --coverage",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write . '!**/.vite-build-check/**' '!dist/**' '!dist-plan/**' '!dist-verify/**'",
		"format:check": "oxfmt . '!**/.vite-build-check/**' '!dist/**' '!dist-plan/**' '!dist-verify/**'",
		"preinstall": "node -e \"if(!(process.env.npm_config_user_agent || '').startsWith('pnpm/')){console.error('Use pnpm.');process.exit(1)}\""
	},
	"dependencies": {
		"@radix-icons/vue": "^1.0.0",
		"@sentry/vue": "^10.43.0",
		"@vueuse/core": "^14.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dompurify": "^3.3.3",
		"highlight.js": "^11.11.1",
		"lodash": "^4.17.23",
		"lucide-vue-next": "^0.577.0",
		"marked": "^17.0.4",
		"pinia": "^3.0.4",
		"reka-ui": "^2.9.2",
		"tailwind-merge": "^3.5.0",
		"tslib": "^2.8.1",
		"uuid": "^13.0.0",
		"vue": "^3.5.30",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.3.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/lodash": "^4.17.24",
		"@types/node": "^25.5.0",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitest/coverage-v8": "^4.1.0",
		"@vue/test-utils": "^2.4.6",
		"jsdom": "^29.0.0",
		"oxfmt": "^0.40.0",
		"oxlint": "^1.55.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	},
	"packageManager": "pnpm@10.31.0",
	"knip": {
		"ignoreBinaries": [
			"make"
		]
	}
}
